<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="@dimen/search_result_item_height"
    android:layout_marginBottom="@dimen/spacing_sm"
    android:background="@drawable/bg_card"
    android:focusable="true"
    android:focusableInTouchMode="true"
    android:padding="@dimen/spacing_md">

    <ImageView
        android:id="@+id/videoPoster"
        android:layout_width="60dp"
        android:layout_height="80dp"
        android:scaleType="centerCrop"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/videoTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/spacing_md"
        android:ellipsize="end"
        android:maxLines="1"
        android:textColor="@color/text_primary"
        android:textSize="@dimen/text_size_body"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/videoPoster"
        app:layout_constraintTop_toTopOf="@id/videoPoster" />

    <TextView
        android:id="@+id/videoCategories"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/spacing_md"
        android:layout_marginTop="@dimen/spacing_xs"
        android:ellipsize="end"
        android:maxLines="1"
        android:textColor="@color/text_tertiary"
        android:textSize="@dimen/text_size_caption"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/videoPoster"
        app:layout_constraintTop_toBottomOf="@id/videoTitle" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/spacing_md"
        android:layout_marginTop="@dimen/spacing_xs"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        app:layout_constraintBottom_toBottomOf="@id/videoPoster"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/videoPoster">

        <TextView
            android:id="@+id/videoRating"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@color/focus_highlight"
            android:paddingHorizontal="@dimen/spacing_xs"
            android:paddingVertical="2dp"
            android:textColor="@color/white"
            android:textSize="@dimen/text_size_caption" />

        <TextView
            android:id="@+id/videoYear"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/spacing_md"
            android:textColor="@color/text_tertiary"
            android:textSize="@dimen/text_size_caption" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
